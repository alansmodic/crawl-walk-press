{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"color": {
			"palette": [
				{
					"color": "#fafaf9",
					"name": "Base",
					"slug": "base"
				},
				{
					"color": "#1e293b",
					"name": "Contrast",
					"slug": "contrast"
				},
				{
					"color": "#4f46e5",
					"name": "Primary",
					"slug": "accent-1"
				},
				{
					"color": "#f59e0b",
					"name": "Accent Warm",
					"slug": "accent-2"
				},
				{
					"color": "#7c3aed",
					"name": "Primary Light",
					"slug": "accent-3"
				},
				{
					"color": "#64748b",
					"name": "Muted",
					"slug": "accent-4"
				},
				{
					"color": "#f1f5f9",
					"name": "Surface",
					"slug": "accent-5"
				},
				{
					"color": "color-mix(in srgb, currentColor 12%, transparent)",
					"name": "Border",
					"slug": "accent-6"
				}
			]
		},
		"layout": {
			"contentSize": "720px",
			"wideSize": "1100px"
		},
		"typography": {
			"fontFamilies": [
				{
					"name": "Inter",
					"slug": "inter",
					"fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
					"fontFace": [
						{
							"src": ["https://fonts.gstatic.com/s/inter/v18/UcCO3FwrK3iLTeHuS_nVMrMxCp50SjIw2boKoduKmMEVuLyfAZ9hiA.woff2"],
							"fontWeight": "100 900",
							"fontStyle": "normal",
							"fontFamily": "Inter"
						}
					]
				},
				{
					"name": "Fira Code",
					"slug": "fira-code",
					"fontFamily": "\"Fira Code\", \"JetBrains Mono\", \"SF Mono\", monospace",
					"fontFace": [
						{
							"src": [
								"file:./../../twentytwentyfive/assets/fonts/fira-code/FiraCode-VariableFont_wght.woff2"
							],
							"fontWeight": "300 700",
							"fontStyle": "normal",
							"fontFamily": "\"Fira Code\""
						}
					]
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var:preset|color|base",
			"text": "var:preset|color|contrast"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|inter",
			"fontSize": "var:preset|font-size|medium",
			"fontWeight": "400",
			"letterSpacing": "-0.01em",
			"lineHeight": "1.65"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontWeight": "700",
					"lineHeight": "1.2",
					"letterSpacing": "-0.02em"
				},
				"color": {
					"text": "#0f172a"
				}
			},
			"h1": {
				"typography": {
					"fontWeight": "900",
					"letterSpacing": "-0.03em"
				}
			},
			"h2": {
				"typography": {
					"fontWeight": "800"
				}
			},
			"h3": {
				"typography": {
					"fontWeight": "700"
				},
				"color": {
					"text": "var:preset|color|accent-3"
				}
			},
			"link": {
				"color": {
					"text": "var:preset|color|accent-1"
				},
				":hover": {
					"color": {
						"text": "var:preset|color|accent-3"
					}
				}
			},
			"button": {
				"color": {
					"background": "var:preset|color|accent-1",
					"text": "#ffffff"
				},
				":hover": {
					"color": {
						"background": "var:preset|color|accent-3"
					}
				},
				"border": {
					"radius": "8px"
				}
			}
		},
		"blocks": {
			"core/code": {
				"typography": {
					"fontFamily": "var:preset|font-family|fira-code",
					"fontSize": "0.85rem"
				}
			},
			"core/site-title": {
				"typography": {
					"fontWeight": "800",
					"letterSpacing": "-0.02em"
				}
			},
			"core/navigation": {
				"typography": {
					"fontWeight": "500",
					"fontSize": "var:preset|font-size|small"
				}
			}
		}
	}
}
